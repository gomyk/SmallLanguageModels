data/*.csv
# EXCEPTION: keep the MTEB distillation corpus so training data is byte-identical
# across environments (set()-based dedup is NOT deterministic on regeneration).
!data/distill_corpus/mteb_distill_10000.txt
!data/distill_corpus/distill_texts_5000.txt

